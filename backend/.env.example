# === Database ===
DATABASE_URL=sqlite+aiosqlite:///./app.db
# For production PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_recruiter

# === Auth ===
JWT_SECRET_KEY=change-this-to-a-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# === Embedding ===
# Options: hash (no deps, for testing), ollama (requires Ollama running), sentence-transformers (local)
EMBEDDING_PROVIDER=hash
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# all-MiniLM-L6-v2/hash = 384, nomic-embed-text = 768
EMBEDDING_DIMENSION=384

# === LLM (optional) ===
LLM_PROVIDER=rule
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=gemma3:4b

# === Redis (optional) ===
REDIS_URL=redis://localhost:6379/0

# === App ===
APP_NAME=AI Recruiter Assistant
ENVIRONMENT=development
LOG_LEVEL=INFO
API_PREFIX=/api/v1
APP_BASE_URL=http://localhost:5173

# === Gmail SMTP ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
